# ============================================
# VARIABLES DE ENTORNO PARA BACKEND DJANGO
# ============================================
# Copia este archivo como backend/.env para desarrollo local.
# Nunca versiones backend/.env ni otros archivos con secretos reales.

DJANGO_SECRET_KEY=coloca_una_clave_larga_y_segura_aqui
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base de datos actual de desarrollo: SQLite.
# Ruta actual usada por settings.py: backend/db.sqlite3.
# SQL Server no está implementado en la configuración actual y no debe considerarse activo todavía.
